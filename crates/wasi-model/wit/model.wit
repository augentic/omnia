// wit/model.wit — omnia:model@0.1.0
//
// This is the authoritative WIT for the `omnia:model/completion` interface
// (rfcs/wasi-model.md §3.1). Two deliberate deviations from the prose WIT in the
// RFC, made because the established host-crate patterns win where they differ
// (RFC §3.2):
//
//  1. `create` / `create-stream` are `async func` (not plain `func`). Every
//     backend-touching WASI function in this codebase is an `async func`
//     implemented in wasmtime's concurrent (`store`) mode — see
//     `wasi-blobstore`'s `create-container: async func`. `create` calls an
//     async backend (`WasiModelCtx::complete` returns a future), so it must be
//     `async func` for the host binding to await it without blocking the
//     executor.
//  2. The workspace handle tracks `wasi:filesystem@0.3.0` (p3) — the version
//     the runtime serves via `wasmtime_wasi::p3::add_to_linker` — so the `with:`
//     remap onto wasmtime's p3 `Descriptor` resolves to the same resource the
//     runtime already owns. p3 filesystem reads ride native component-model
//     `stream`/`future`, so the boundary no longer pulls in `wasi:io` (RFC-55).
package omnia:model@0.1.0;

/// Models-API-style prompt completion. Guests import `omnia:model/completion`.
interface completion {
    /// Workspace handle lent through `grants.workspace`. The host resolves the lent
    /// descriptor to an authorized mount by directory identity, then exposes it to
    /// backends as bounded `read`/`list`/`write` (genai) and the absolute
    /// `local-path` (cursor's `--workspace`).
    use wasi:filesystem/types@0.3.0.{descriptor};

    /// JSON document encoded as UTF-8 text.
    type json = string;

    /// JSON document returned to the guest; validated per `request.format`.
    type answer = string;

    /// Chat turn author.
    enum role {
        /// System / instructions channel.
        system,
        /// End-user turn.
        user,
        /// Model turn.
        assistant,
    }

    /// One chat turn passed to the provider API.
    record message {
        /// Turn author.
        role: role,
        /// Turn body text.
        content: string,
    }

    /// One few-shot pair used when assembling from `sections`.
    record example {
        /// Example user input.
        input: string,
        /// Example model output.
        output: string,
    }

    /// Named substitution slot applied when assembling section text.
    record variable {
        /// Placeholder name (e.g. `language`).
        name: string,
        /// Value substituted for `name`.
        value: string,
    }

    /// Structured prompt template; used when `request.messages` is empty.
    record sections {
        /// Persona / actor instruction.
        role: option<string>,
        /// What the model should do. Required when assembling from sections.
        task: string,
        /// Background documents, prior state, or prior turns.
        context: option<string>,
        /// Rules, limits, and things to avoid.
        constraints: list<string>,
        /// Few-shot input/output pairs.
        examples: list<example>,
        /// Template variables applied during assembly.
        variables: list<variable>,
    }

    /// JSON Schema constrained output (`response_format.json_schema` in provider APIs).
    record schema {
        /// Schema name passed to the provider (e.g. `review_result`).
        name: string,
        /// JSON Schema document the answer must conform to.
        schema: json,
        // YAGNI (Tier 1): never forwarded to a provider — genai's `JsonSpec`
        // ignores it and cursor embeds only the schema text. Re-add when a
        // backend actually honors provider strict mode.
        // /// Provider strict-mode hint when supported.
        // strict: option<bool>,
    }

    /// Output shape constraint for the completion.
    variant format {
        /// Answer must be a JSON string value.
        text,
        /// Answer must parse as a JSON object.
        json,
        /// Answer must validate against the given JSON Schema.
        schema(schema),
    }

    /// Reasoning-effort hint for models that expose a thinking budget.
    enum effort {
        /// Least reasoning; lowest latency and cost.
        minimal,
        /// Reduced reasoning.
        low,
        /// Balanced reasoning.
        medium,
        /// Most reasoning; highest latency and cost.
        high,
    }

    /// Sampling and length controls. Omitted fields defer to backend defaults.
    record generation {
        /// Sampling temperature.
        temperature: option<f32>,
        /// Nucleus sampling threshold.
        top-p: option<f32>,
        // YAGNI (Tier 1): not forwardable to any current backend — genai exposes
        // no top-k control and cursor ignores `generation` entirely.
        // /// Top-k sampling cutoff.
        // top-k: option<u32>,
        /// Maximum output tokens.
        max-tokens: option<u32>,
        /// Sequences that halt generation.
        stop: list<string>,
        /// Seed for reproducible sampling when the provider supports it.
        seed: option<u64>,
        /// Reasoning-effort hint for thinking-capable models.
        effort: option<effort>,
    }

    /// Guest-declared function tool advertised to the model.
    record function {
        /// Tool name. Must not collide with reserved host-injected tool names (`resolve`, `read`, …).
        name: string,
        /// Natural-language description for the model.
        description: string,
        /// JSON Schema for the tool's arguments object.
        parameters: json,
    }

    /// Remote MCP server offered to the model for this completion. The guest
    /// supplies the endpoint `url` directly — the single source of truth for
    /// where the server lives.
    record mcp {
        /// Logical server name identifying the server (e.g. in `.cursor/mcp.json`).
        name: string,
        /// Tool allowlist; empty exposes every tool the server advertises.
        tools: list<string>,
        /// MCP server endpoint URL. Backends that wire MCP require this.
        url: option<string>,
    }

    /// A tool offered to the model: a guest-declared function or a named MCP server.
    variant tool {
        /// Guest-declared function tool.
        function(function),
        /// Named MCP server grant, resolved to an endpoint by the host.
        mcp(mcp),
    }

    // YAGNI (Tier 1): no backend maps a tool-choice policy onto its provider
    // (genai and cursor both ignore it), so both the variant and the
    // `request.tool-choice` field below are commented out until one does.
    // /// Tool selection policy (`tool_choice` in provider APIs).
    // variant tool-choice {
    //     /// Provider selects whether to call tools.
    //     auto,
    //     /// Do not call tools.
    //     none,
    //     /// Must call at least one tool.
    //     required,
    //     /// Must call the named tool.
    //     named(string),
    // }

    /// Host capabilities lent for this completion; drives host-injected tool injection.
    record grants {
        /// Guest id whose `references` export `resolve` targets.
        references: option<string>,
        /// Typed `wasi:filesystem` capability for bounded `read` / `list` / `write`
        /// (genai) and the spawned agent's direct access (cursor). A `borrow`, so the
        /// The runtime core never trusts a forgeable integer handle — the host resolves it from
        /// the resource table exactly as other hosts take typed resources.
        workspace: option<borrow<descriptor>>,
        /// Allowed closed verification profile names for `verify`.
        verify: list<string>,
    }

    /// Complete models-API-style request for one completion.
    record request {
        /// Opaque model id hint; passed through unchanged. Backend may override.
        model: option<string>,
        /// System / instructions channel. Applied per assembly rules (§3.1.1).
        system: option<string>,
        /// Explicit chat turns. When non-empty, takes precedence over `sections`.
        messages: list<message>,
        /// Structured template used when `messages` is empty.
        sections: option<sections>,
        /// Sampling and length controls.
        generation: option<generation>,
        /// Required output shape and validation rules.
        format: format,
        /// Guest-declared functions and MCP grants merged with host-injected tools at the backend.
        tools: list<tool>,
        // YAGNI (Tier 1): never honored by a backend; see the `tool-choice` variant above.
        // /// Tool selection policy. Defaults to provider/backend `auto`.
        // tool-choice: option<tool-choice>,
        // YAGNI (Tier 1): never read by any backend and not part of the replay key.
        // /// Tracing and attribution metadata (key/value pairs).
        // metadata: list<tuple<string, string>>,
        /// Host capabilities lent for this call.
        grants: grants,
    }

    /// Token accounting for one completion, when the backend reports it.
    record usage {
        /// Prompt tokens consumed.
        input-tokens: u32,
        /// Completion tokens produced.
        output-tokens: u32,
        /// Reasoning tokens, for models that bill them separately.
        reasoning-tokens: option<u32>,
    }

    /// One validated completion result.
    record reply {
        /// The validated JSON answer, per `request.format`.
        answer: answer,
        /// Token accounting, when the backend reports it.
        usage: option<usage>,
    }

    /// Incremental output from `create-stream`.
    variant event {
        /// Token or fragment; diagnostic only, not validated until `done`.
        delta(string),
        /// Terminal success — the same validated `reply` as `create` would return.
        done(reply),
        /// Terminal failure mid-stream.
        failed(error),
    }

    /// Typed completion failure.
    variant error {
        /// Backend produced output that never passed validation.
        invalid-answer(string),
        /// Iteration, token, time, or verify budget exhausted.
        budget-exhausted(string),
        /// Non-repairable tool error.
        tool-failed(string),
        /// Transport, process, or provider failure.
        backend(string),
    }

    /// Single-shot completion — returns one validated `reply`.
    create: async func(request: request) -> result<reply, error>;

    /// Streaming completion over the same `request`. Read until `done` or `failed`.
    create-stream: async func(request: request) -> result<stream<event>, error>;
}

/// Guest world: import and call `completion`.
world model {
    import completion;
}
