// A trivial host-mediated interface used to prove guest-to-guest dynamic
// linking.
//
// The caller (`router`) *imports* `echo`; the host has polyfilled that import on
// the shared linker, so invoking it runs the runtime core's selector, picks the target
// guest, and dispatches the call over the in-process wRPC carrier to whichever
// guest *exports* `echo` (`responder`). Caller and callee share one interface —
// the adapter pattern — so the leading `target` argument the default
// `FirstArgSelector` reads is forwarded straight through to the export.
package omnia:link;

/// The host-mediated interface. Resource-free by design: resource handles
/// never cross the link seam.
interface echo {
    /// Echo `message`, tagged with the responder's identity. `target` names the
    /// guest that should answer (read by the default selector) and is forwarded
    /// through to the export unchanged.
    echo: func(target: string, message: string) -> string;

    /// The async-typed dual of `echo`. The responder parks on a host timer
    /// before answering, so the callee is genuinely pending while the dispatch
    /// round-trip is in flight.
    echo-slow: async func(target: string, message: string) -> string;
}

/// The responder guest: serves `echo`. It declares no trigger of its own — it is
/// reachable *only* through host-mediated dispatch. The clock import backs
/// `echo-slow`'s pending await.
world responder {
    import wasi:clocks/monotonic-clock@0.3.0;
    export echo;
}

/// The router guest: imports the host-mediated `echo` and exposes plain `run` /
/// `run-slow` entries that call it. `run-slow` is itself async-lifted — a
/// sync-lifted export cannot call the async-typed `echo-slow` import.
/// `run-to` / `run-to-slow` forward an arbitrary target, reaching guests
/// registered after startup (dynamic registration).
world router {
    import echo;
    export run: func(message: string) -> string;
    export run-slow: async func(message: string) -> string;
    export run-to: func(target: string, message: string) -> string;
    export run-to-slow: async func(target: string, message: string) -> string;
}
