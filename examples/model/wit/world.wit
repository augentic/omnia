// The model example guest's world: import the `completion` boundary and expose a
// plain `run` entry the integration test drives (the `complete` guest is reached
// via CLI / test, not an HTTP or messaging trigger). `run` is `async func`
// because `complete` is an async import the guest must `await`.
package augentic:model-example@0.1.0;

world complete {
    import augentic:model/completion@0.1.0;
    export run: async func() -> string;
}
